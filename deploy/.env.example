# Postgres
POSTGRES_USER=digitalcheck
POSTGRES_PASSWORD=digitalcheck
POSTGRES_DB=digitalcheck

# Backend
# Generá uno fuerte: openssl rand -base64 48
JWT_SECRET=cambiame-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=12h

# Como Nginx proxya /api al backend, todas las requests son same-origin.
# Igual dejamos CORS_ORIGIN=* para evitar problemas si se accede al backend
# directamente por algún motivo durante debugging.
CORS_ORIGIN=*

# Puerto público en la VM (en Azure abrir este puerto en el NSG)
PUBLIC_PORT=80
